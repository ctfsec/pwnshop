<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= currentCategory ? currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1) : 'Categories' %> - Pwnshop</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css">
    <style>

        /* ── LAYOUT ── */
        .page-wrap { display: grid; grid-template-columns: 220px 1fr; gap: 24px; max-width: 1400px; margin: 28px auto; padding: 0 20px; }
        aside { position: sticky; top: 80px; align-self: start; }

        /* ── CONTENT HEADER ── */
        .content-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; flex-wrap: wrap; gap: 12px; }
        .content-header h2 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.4rem; color: var(--black); margin: 0; }
        .sort-group { display: flex; gap: 6px; align-items: center; }
        .sort-group span { font-size: 0.82rem; color: var(--gray-500); }
        .sort-btn { background: var(--white); border: 1.5px solid var(--gray-200); color: var(--gray-500); border-radius: 8px; padding: 6px 14px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.18s; font-family: 'DM Sans', sans-serif; }
        .sort-btn:hover, .sort-btn.active { background: var(--purple-pale); border-color: var(--purple-mid); color: var(--purple-mid); }

        /* ── PRODUCT CARDS ── */
        .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
        .product-card-img-wrap { height: 160px; }
        .product-card-body { padding: 12px 14px 14px; }
        .product-name { font-size: 0.9rem; }
        .product-price { font-size: 1.05rem; margin-bottom: 3px; }
        .product-category { margin-bottom: 10px; }
        .btn-view, .btn-addcart { padding: 8px 0; font-size: 0.85rem; }
        @media (max-width: 992px) {
            .page-wrap { grid-template-columns: 1fr !important; }
            .products-grid { grid-template-columns: repeat(2, 1fr) !important; }
            aside { position: static; }
        }
        @media (max-width: 480px) {
            .products-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 10px !important; }
            .product-card-img-wrap { height: 130px; }
        }

        /* ── EMPTY STATE ── */
        .empty-state { text-align: center; padding: 80px 20px; background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); }
        .empty-state i { font-size: 3rem; color: var(--gray-200); margin-bottom: 16px; display: block; }
        .empty-state h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--black); margin-bottom: 6px; }
        .empty-state p { color: var(--gray-500); font-size: 0.88rem; }

        /* ── FOOTER ── */
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <form class="search-wrap" action="/search" method="GET">
            <input type="search" name="q" placeholder="Search products, brands, categories...">
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
        <ul class="nav-right">
            <li><a class="nav-link" href="/vulnerabilities"><i class="bi bi-question-circle"></i> Help</a></li>
            <% if (user && user.role === 'user' && !user.isSeller) { %>
                <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
            <% } %>
            <% if (user && user.isSeller) { %>
                <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
                <li><a href="/seller/dashboard" class="btn-dashboard"><i class="bi bi-graph-up"></i> Dashboard</a></li>
            <% } %>
            <li>
                <% if (user) { %>
                    <a href="/profile" class="user-chip"><%= user.username %></a>
                    <a href="/logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-login"><i class="bi bi-person"></i> Login / Signup</a>
                <% } %>
            </li>
            <li>
                <a class="btn-cart" href="/cart">
                    <i class="bi bi-cart3"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                </a>
            </li>
        </ul>
    </div>
</nav>

<div class="page-wrap two-col">


    <aside>
        <div class="sidebar">
            <h5>Categories</h5>
            <a href="/category/all"         class="cat-btn <%= currentCategory === 'all' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-grid-fill"></i></span> All Categories</a>
            <a href="/category/computers"   class="cat-btn <%= currentCategory === 'computers' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-laptop"></i></span> Computers &amp; Accessories</a>
            <a href="/category/phones"      class="cat-btn <%= currentCategory === 'phones' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-phone"></i></span> Phones &amp; Tablets</a>
            <a href="/category/electronics" class="cat-btn <%= currentCategory === 'electronics' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-lightning-charge"></i></span> Electronics</a>
            <a href="/category/fashion"     class="cat-btn <%= currentCategory === 'fashion' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-bag"></i></span> Fashion</a>
            <a href="/category/home"        class="cat-btn <%= currentCategory === 'home' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-house"></i></span> Home &amp; Kitchen</a>
            <a href="/category/kids"        class="cat-btn <%= currentCategory === 'kids' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-star"></i></span> Kids &amp; Toys</a>
            <a href="/category/beauty"      class="cat-btn <%= currentCategory === 'beauty' ? 'active' : '' %>"><span class="cat-icon"><i class="bi bi-heart"></i></span> Beauty &amp; Health</a>
        </div>
        <%
            const _fsExpiry = new Date('2036-01-01');
            const _fsDays   = Math.max(0, Math.ceil((_fsExpiry - new Date()) / (1000*60*60*24)));
        %>
        <div class="sidebar-promo">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                <h6 style="margin:0;">Flash Sale 🔥</h6>
                <span style="font-size:0.68rem;font-weight:700;background:rgba(255,255,255,0.2);padding:2px 8px;border-radius:20px;white-space:nowrap;"><%= _fsDays %>d left</span>
            </div>
            <p>Up to 60% off selected items</p>
            <a href="/category/all" class="promo-btn">Shop Now</a>
        </div>
    </aside>


    <main>
        <div class="content-header">
            <h2><%= currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1) %></h2>
            <div class="sort-group">
                <span>Sort by:</span>
                <button class="sort-btn <%= currentSort === 'relevance' ? 'active' : '' %>"
                    onclick="location.href='/category/<%= currentCategory %>'">Relevance</button>
                <button class="sort-btn <%= currentSort === 'high' ? 'active' : '' %>"
                    onclick="location.href='/category/<%= currentCategory %>?sort=high'">Price: High to Low</button>
                <button class="sort-btn <%= currentSort === 'low' ? 'active' : '' %>"
                    onclick="location.href='/category/<%= currentCategory %>?sort=low'">Price: Low to High</button>
            </div>
        </div>

        <% if (products.length === 0) { %>
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <h3>No products found</h3>
                <p>There are no products in this category yet.</p>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% products.forEach(function(product) { %>
                    <div class="product-card">
                        <div class="product-card-img-wrap">
                            <img src="<%= product.image && product.image !== '' ? product.image : '/images/pc.jpg' %>" alt="<%= product.name %>">
                            <% if (product.deal_price != null) { %>
                            <span class="deal-pct-badge">-<%= Math.round((1 - parseFloat(product.deal_price)/parseFloat(product.price))*100) %>%</span>
                            <% } %>
                        </div>
                        <div class="product-card-body">
                            <div class="product-name"><%= product.name %></div>
                            <% if (product.deal_price != null) { %>
                            <div class="product-price deal-price">₦<%= fmtPrice(product.deal_price) %> <span class="original-price">₦<%= fmtPrice(product.price) %></span></div>
                            <% } else { %>
                            <div class="product-price">₦<%= fmtPrice(product.price) %></div>
                            <% } %>
                            <div class="product-actions">
                                <a href="/product/<%= product.id %>" class="btn-view">View</a>
                                <form method="POST" action="/cart/add" style="flex:1;display:flex;">
                                    <input type="hidden" name="product_id" value="<%= product.id %>">
                                    <input type="hidden" name="quantity" value="1">
                                    <button type="submit" class="btn-addcart" style="width:100%">Add to Cart</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script src="/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
<script>
(function alignFlashSale() {
    var grid      = document.querySelector('.products-grid');
    var flashCard = document.querySelector('.sidebar-promo');
    if (!grid || !flashCard) return;
    function sync() {
        flashCard.style.minHeight      = '';
        flashCard.style.display        = '';
        flashCard.style.flexDirection  = '';
        flashCard.style.justifyContent = '';

        var cards    = Array.from(grid.querySelectorAll('.product-card'));
        if (!cards.length) return;
        var flashTop = flashCard.getBoundingClientRect().top + window.scrollY;

        /* collect one bottom value per row (every 4th card since grid is 4-col) */
        var rowBottoms = [];
        for (var i = 3; i < cards.length; i += 4)
            rowBottoms.push(cards[i].getBoundingClientRect().bottom + window.scrollY);
        /* include the last partial row */
        var lastB = cards[cards.length - 1].getBoundingClientRect().bottom + window.scrollY;
        if (!rowBottoms.length || rowBottoms[rowBottoms.length - 1] < lastB - 2)
            rowBottoms.push(lastB);

        /* align with the first complete row so the card stays compact */
        var target = rowBottoms[0] || lastB;

        var h = target - flashTop;
        if (h > 60) {
            flashCard.style.minHeight      = h + 'px';
            flashCard.style.display        = 'flex';
            flashCard.style.flexDirection  = 'column';
            flashCard.style.justifyContent = 'center';
        }
    }
    window.addEventListener('load',   sync);
    window.addEventListener('resize', sync);
    sync();
})();
</script>

</body>
</html>
