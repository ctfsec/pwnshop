<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Your Order - Pwnshop</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css?v=2">
    <style>
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(135deg, var(--purple-deep) 0%, #4c0099 100%);
            padding: 60px 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: rgba(168,85,247,0.1);
            border-radius: 50%;
            top: -100px; right: -100px;
        }
        .hero::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: rgba(192,38,211,0.08);
            border-radius: 50%;
            bottom: -80px; left: -80px;
        }
        .hero-content { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
        .hero-icon { width: 64px; height: 64px; background: rgba(255,255,255,0.1); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 1.8rem; color: var(--white); }
        .hero h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem; color: var(--white); margin-bottom: 10px; }
        .hero p { color: rgba(255,255,255,0.7); font-size: 0.95rem; margin-bottom: 36px; }

        /* ── SEARCH CARD ── */
        .search-card {
            background: var(--white);
            border-radius: 16px;
            padding: 28px 28px 24px;
            box-shadow: 0 8px 32px rgba(59,7,100,0.18);
            max-width: 500px;
            margin: 0 auto;
        }
        .f-label { font-size: 0.78rem; font-weight: 600; color: var(--black); margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; display: block; }
        .f-field { border: 1.5px solid var(--gray-200); border-radius: 10px; padding: 11px 14px; font-size: 0.9rem; font-family: 'DM Sans', sans-serif; width: 100%; outline: none; transition: border-color 0.2s, box-shadow 0.2s; color: var(--black); background: var(--white); }
        .f-field:focus { border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
        .f-field::placeholder { color: #b0afc0; }
        .btn-track { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 13px; font-size: 0.92rem; font-weight: 700; font-family: 'DM Sans', sans-serif; width: 100%; cursor: pointer; transition: background 0.2s, transform 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 4px; }
        .btn-track:hover { background: var(--purple-mid); transform: translateY(-1px); }

        /* ── INFO STRIPS ── */
        .info-strip { max-width: 860px; margin: 48px auto; padding: 0 20px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .info-item { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); padding: 20px; text-align: center; }
        .info-item i { font-size: 1.5rem; color: var(--purple-mid); display: block; margin-bottom: 10px; }
        .info-item h4 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.88rem; color: var(--black); margin-bottom: 4px; }
        .info-item p { font-size: 0.78rem; color: var(--gray-500); }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <form class="search-wrap" action="/search" method="GET">
            <input type="search" name="q" placeholder="Search products, brands, categories...">
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
        <ul class="nav-right">
            <li><a class="nav-link" href="/vulnerabilities"><i class="bi bi-question-circle"></i> Help</a></li>
            <% if (user && user.role === 'user' && !user.isSeller) { %>
                <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
            <% } %>
            <% if (user && user.isSeller) { %>
                <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
                <li><a href="/seller/dashboard" class="btn-dashboard"><i class="bi bi-graph-up"></i> Dashboard</a></li>
            <% } %>
            <li>
                <% if (user) { %>
                    <a href="/profile" class="user-chip"><%= user.username %></a>
                    <a href="/logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-login"><i class="bi bi-person"></i> Login / Signup</a>
                <% } %>
            </li>
            <li>
                <a class="btn-cart" href="/cart">
                    <i class="bi bi-cart3"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                </a>
            </li>
        </ul>
    </div>
</nav>

<div class="hero">
    <div class="hero-content">
        <div class="hero-icon"><i class="bi bi-geo-alt-fill"></i></div>
        <h1>Track Your Order</h1>
        <p>Enter your order number and email address to get real-time updates on your delivery.</p>

        <div class="search-card">
            <% if (error) { %>
                <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i> <%= error %></div>
            <% } %>

            <form method="POST" action="/track">
                <div class="mb-3">
                    <label class="f-label">Order Number</label>
                    <input type="text" class="f-field" name="order_id" placeholder="e.g. 1042" required>
                </div>
                <div class="mb-4">
                    <label class="f-label">Email Address</label>
                    <input type="email" class="f-field" id="trackEmail" name="email" placeholder="you@example.com" required>
                    <span id="trackEmailHint" style="display:block;font-size:0.72rem;margin-top:4px;min-height:16px;"></span>
                </div>
                <button type="submit" class="btn-track">
                    <i class="bi bi-search"></i> Track Order
                </button>
            </form>
        </div>
    </div>
</div>

<div class="info-strip">
    <div class="info-item">
        <i class="bi bi-clock-history"></i>
        <h4>Real-Time Updates</h4>
        <p>See every status change from the moment your order is placed to delivery.</p>
    </div>
    <div class="info-item">
        <i class="bi bi-geo-alt"></i>
        <h4>Live Map</h4>
        <p>View your order's current delivery location on an interactive map.</p>
    </div>
    <div class="info-item">
        <i class="bi bi-bell"></i>
        <h4>Status History</h4>
        <p>Full timeline of every update with timestamps and notes from our team.</p>
    </div>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script src="/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
<script>
    (function(){
        var el = document.getElementById('trackEmail'), hint = document.getElementById('trackEmailHint');
        if(!el) return;
        function check(){ var v=el.value.trim(); if(!v){el.style.borderColor='';hint.textContent='';return;} var ok=/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v); el.style.borderColor=ok?'#22c55e':'#ef4444'; hint.style.color=ok?'#16a34a':'#ef4444'; hint.textContent=ok?'':'Please enter a valid email address'; }
        el.addEventListener('input',check); el.addEventListener('blur',check);
    })();
</script>
</body>
</html>
