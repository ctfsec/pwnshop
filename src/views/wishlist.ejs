<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= wishlistOwner ? wishlistOwner.username + "'s Wishlist" : 'Wishlist' %> - Pwnshop</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css?v=2">
    <style>
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        .page-wrap { max-width: 1100px; margin: 36px auto; padding: 0 20px 60px; }

        .page-header { margin-bottom: 28px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
        .page-header h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.4rem; color: var(--black); margin: 0; display: flex; align-items: center; gap: 10px; }
        .page-header h1 i { color: var(--accent); }
        .page-header p { color: var(--gray-500); font-size: 0.85rem; margin: 4px 0 0; }
        .count-tag { background: var(--purple-pale); color: var(--purple-mid); font-size: 0.78rem; font-weight: 700; border-radius: 20px; padding: 3px 12px; }

        .wishlist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 20px; }
        .wl-card { background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); overflow: hidden; transition: all 0.22s; }
        .wl-card:hover { border-color: var(--purple-light); box-shadow: 0 8px 28px rgba(109,40,217,0.13); transform: translateY(-4px); }
        .wl-card img { height: 175px; width: 100%; object-fit: cover; }
        .wl-card-placeholder { height: 175px; width: 100%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; color: var(--gray-200); font-size: 2.5rem; }
        .wl-card-body { padding: 14px 16px 16px; }
        .wl-name { font-weight: 600; font-size: 0.92rem; color: var(--black); margin-bottom: 4px; line-height: 1.3; }
        .wl-price { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--purple-mid); margin-bottom: 12px; }
        .wl-cat { font-size: 0.75rem; color: var(--gray-500); background: var(--gray-100); display: inline-block; padding: 2px 8px; border-radius: 4px; margin-bottom: 12px; }
        .btn-wl-view { display: block; background: var(--purple-deep); color: var(--white); border: none; border-radius: 8px; padding: 8px; font-size: 0.82rem; font-weight: 700; text-align: center; text-decoration: none; transition: background 0.18s; }
        .btn-wl-view:hover { background: var(--purple-mid); color: var(--white); }

        .empty-state { text-align: center; padding: 80px 20px; background: var(--white); border-radius: 14px; border: 1.5px solid var(--gray-200); }
        .empty-state i { font-size: 3rem; color: var(--gray-200); display: block; margin-bottom: 14px; }
        .empty-state h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--black); margin-bottom: 6px; }
        .empty-state p { color: var(--gray-500); font-size: 0.85rem; }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <form class="search-wrap" action="/search" method="GET">
            <input type="search" name="q" placeholder="Search products, brands, categories...">
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
        <ul class="nav-right">
            <li><a class="nav-link" href="/vulnerabilities"><i class="bi bi-question-circle"></i> Help</a></li>
            <% if (user && user.role === 'user' && !user.isSeller) { %>
                <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
            <% } %>
            <% if (user && user.isSeller) { %>
                <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
                <li><a href="/seller/dashboard" class="btn-dashboard"><i class="bi bi-graph-up"></i> Dashboard</a></li>
            <% } %>
            <li>
                <% if (user) { %>
                    <a href="/profile" class="user-chip"><%= user.username %></a>
                    <a href="/logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-login"><i class="bi bi-person"></i> Login / Signup</a>
                <% } %>
            </li>
            <li>
                <a class="btn-cart" href="/cart">
                    <i class="bi bi-cart3"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                </a>
            </li>
        </ul>
    </div>
</nav>

<div class="page-wrap">

    <div class="page-header">
        <div>
            <h1><i class="bi bi-heart-fill"></i>
                <%= wishlistOwner ? wishlistOwner.username + "'s Wishlist" : 'Wishlist' %>
            </h1>
            <p>Saved products</p>
        </div>
        <span class="count-tag"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %></span>
    </div>

    <% if (items.length === 0) { %>
        <div class="empty-state">
            <i class="bi bi-heart"></i>
            <h3>Nothing saved yet</h3>
            <p>This wishlist is empty.</p>
        </div>
    <% } else { %>
        <div class="wishlist-grid">
            <% items.forEach(item => { %>
                <div class="wl-card">
                    <% if (item.image && item.image !== '') { %>
                        <img src="<%= item.image %>" alt="<%= item.name %>">
                    <% } else { %>
                        <div class="wl-card-placeholder"><i class="bi bi-image"></i></div>
                    <% } %>
                    <div class="wl-card-body">
                        <div class="wl-name"><%= item.name %></div>
                        <div class="wl-price">₦<%= fmtPrice(item.price) %></div>
                        <span class="wl-cat"><%= item.category %></span>
                        <a href="/product/<%= item.product_id %>" class="btn-wl-view">View Product</a>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>

</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script src="/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>

</body>
</html>
