<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Pwnshop</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css?v=2">
    <style>
        body { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .auth-card { background: var(--white); border-radius: 20px; box-shadow: 0 8px 40px rgba(59,7,100,0.13); width: 100%; max-width: 920px; display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; min-height: 520px; }
        .panel-left { background: linear-gradient(145deg, var(--purple-deep), var(--purple-mid)); padding: 48px 40px; display: flex; flex-direction: column; justify-content: space-between; position: relative; overflow: hidden; }
        .panel-left::before { content: ''; position: absolute; width: 260px; height: 260px; background: rgba(168,85,247,0.15); border-radius: 50%; top: -60px; right: -80px; }
        .panel-left::after { content: ''; position: absolute; width: 180px; height: 180px; background: rgba(192,38,211,0.12); border-radius: 50%; bottom: -40px; left: -40px; }
        .brand-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.7rem; color: var(--white); text-decoration: none; display: flex; align-items: center; gap: 8px; position: relative; z-index: 1; }
        .brand-logo .dot { width: 8px; height: 8px; background: var(--purple-light); border-radius: 50%; }
        .panel-body { position: relative; z-index: 1; }
        .panel-body h2 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.9rem; color: var(--white); line-height: 1.25; margin-bottom: 14px; }
        .panel-body p { color: rgba(255,255,255,0.7); font-size: 0.9rem; line-height: 1.6; }
        .panel-perks { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 10px; }
        .perk-item { display: flex; align-items: center; gap: 10px; color: rgba(255,255,255,0.85); font-size: 0.85rem; }
        .perk-item i { font-size: 1rem; color: var(--purple-light); flex-shrink: 0; }
        .panel-right { padding: 48px 44px; display: flex; flex-direction: column; justify-content: center; }
        .panel-right h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.5rem; color: var(--black); margin-bottom: 6px; }
        .panel-right .subtitle { color: var(--gray-500); font-size: 0.875rem; margin-bottom: 24px; }
        .f-label { font-size: 0.78rem; font-weight: 600; color: var(--black); margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; display: block; }
        .f-field { border: 1.5px solid var(--gray-200); border-radius: 10px; padding: 11px 14px; font-size: 0.9rem; font-family: 'DM Sans', sans-serif; width: 100%; outline: none; transition: border-color 0.2s, box-shadow 0.2s; color: var(--black); background: var(--white); }
        .f-field:focus { border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
        .f-field::placeholder { color: #b0afc0; }
        .pw-wrap { position: relative; }
        .pw-wrap .f-field { padding-right: 42px; }
        .pw-toggle { position: absolute; right: 13px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--gray-500); cursor: pointer; font-size: 1rem; padding: 0; }
        .pw-toggle:hover { color: var(--purple-mid); }
        .btn-submit { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 12px; font-size: 0.9rem; font-weight: 700; font-family: 'DM Sans', sans-serif; width: 100%; cursor: pointer; transition: background 0.2s, transform 0.15s; display: flex; align-items: center; justify-content: center; gap: 7px; margin-top: 4px; }
        .btn-submit:hover { background: var(--purple-mid); transform: translateY(-1px); }
        .auth-links { display: flex; justify-content: center; gap: 20px; margin-top: 18px; }
        .auth-links a { color: var(--purple-mid); font-size: 0.82rem; font-weight: 600; text-decoration: none; }
        .auth-links a:hover { color: var(--accent); }
        .btn-inbox { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background: var(--purple-pale); color: var(--purple-deep); border: 1.5px solid rgba(109,40,217,0.25); border-radius: 10px; padding: 11px; font-size: 0.88rem; font-weight: 700; font-family: 'DM Sans', sans-serif; text-decoration: none; transition: all 0.2s; margin-top: 14px; }
        .btn-inbox:hover { background: var(--purple-deep); color: var(--white); border-color: var(--purple-deep); }
        @media (max-width: 640px) {
            .auth-card { grid-template-columns: 1fr; }
            .panel-left { display: none; }
            .panel-right { padding: 36px 28px; }
        }
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>
<div class="auth-card">


    <div class="panel-left">
        <a href="/" class="brand-logo">Pwnshop<span class="dot"></span></a>
        <div class="panel-body">
            <h2>Set a new password.</h2>
            <p>Click the link in the reset email we sent you, or paste the token manually below.</p>
        </div>
        <div class="panel-perks">
            <div class="perk-item"><i class="bi bi-envelope-check"></i><span>Link sent to your email</span></div>
            <div class="perk-item"><i class="bi bi-shield-check"></i><span>Choose a strong password</span></div>
            <div class="perk-item"><i class="bi bi-check2-circle"></i><span>Sign in immediately after reset</span></div>
        </div>
    </div>


    <div class="panel-right">
        <h3>Reset password</h3>
        <p class="subtitle">Enter your reset token and choose a new password.</p>

        <% if (error) { %>
            <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i> <%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> <%= success %></div>
        <% } %>

        <form action="/reset-password" method="POST">
            <div class="mb-3">
                <label class="f-label">Reset Token</label>
                <input type="text" class="f-field" name="token" placeholder="Token from email" maxlength="64" value="<%= prefillToken %>" required>
            </div>
            <div class="mb-4">
                <label class="f-label">New Password</label>
                <div class="pw-wrap">
                    <input type="password" class="f-field" id="pwField" name="new_password" placeholder="Enter new password" required>
                    <button type="button" class="pw-toggle" id="pwToggle">
                        <i class="bi bi-eye" id="pwIcon"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn-submit">
                <i class="bi bi-check-circle-fill"></i> Reset Password
            </button>
        </form>

        <div class="auth-links">
            <a href="/forgot-password"><i class="bi bi-arrow-left"></i> Request New Link</a>
            <a href="/login">Back to Login</a>
        </div>
    </div>

</div>

<script>
    document.getElementById('pwToggle').addEventListener('click', function () {
        const f = document.getElementById('pwField');
        const i = document.getElementById('pwIcon');
        if (f.type === 'password') { f.type = 'text'; i.className = 'bi bi-eye-slash'; }
        else { f.type = 'password'; i.className = 'bi bi-eye'; }
    });
</script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>
</body>
</html>
