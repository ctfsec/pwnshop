<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopping Cart - Pwnshop</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        /* ── PAGE ── */
        .page-wrap { max-width: 1100px; margin: 36px auto; padding: 0 20px 60px; }
        .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--black); margin-bottom: 24px; display: flex; align-items: center; gap: 10px; }

        /* ── LAYOUT ── */
        .cart-layout { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: start; }

        /* ── CART ITEMS ── */
        .cart-card { background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); overflow: hidden; }
        .cart-card-header { padding: 16px 24px; border-bottom: 1.5px solid var(--gray-200); font-size: 0.8rem; font-weight: 700; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.5px; }
        .cart-item { display: grid; grid-template-columns: 80px 1fr auto auto auto; gap: 16px; align-items: center; padding: 20px 24px; border-bottom: 1px solid var(--gray-200); transition: background 0.15s; }
        .cart-item:last-child { border-bottom: none; }
        .cart-item:hover { background: var(--gray-100); }
        .cart-item img { width: 80px; height: 80px; object-fit: cover; border-radius: 10px; border: 1.5px solid var(--gray-200); }
        .item-name { font-weight: 600; font-size: 0.92rem; color: var(--black); margin-bottom: 3px; }
        .item-unit-price { font-size: 0.8rem; color: var(--gray-500); }
        /* ── QTY STEPPER ── */
        .qty-stepper { display: flex; align-items: center; gap: 0; border: 1.5px solid var(--gray-200); border-radius: 8px; overflow: hidden; }
        .qty-stepper button { background: var(--gray-100); border: none; width: 30px; height: 30px; font-size: 1rem; font-weight: 700; color: var(--purple-mid); cursor: pointer; transition: background 0.15s; line-height: 1; font-family: 'DM Sans', sans-serif; }
        .qty-stepper button:hover { background: var(--purple-pale); color: var(--purple-deep); }
        .qty-stepper input[type=number] { width: 42px; height: 30px; border: none; border-left: 1.5px solid var(--gray-200); border-right: 1.5px solid var(--gray-200); text-align: center; font-size: 0.88rem; font-weight: 600; color: var(--black); font-family: 'DM Sans', sans-serif; -moz-appearance: textfield; background: var(--white); }
        .qty-stepper input[type=number]::-webkit-outer-spin-button,
        .qty-stepper input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .qty-stepper input[type=number]:focus { outline: none; }
        .item-subtotal { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; color: var(--purple-mid); white-space: nowrap; }
        .btn-remove { background: none; border: 1.5px solid var(--gray-200); color: var(--gray-500); border-radius: 8px; padding: 6px 10px; font-size: 0.82rem; cursor: pointer; transition: all 0.18s; font-family: 'DM Sans', sans-serif; }
        .btn-remove:hover { background: #fef2f2; border-color: #fecaca; color: #dc2626; }

        /* ── ORDER SUMMARY ── */
        .summary-card { background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); padding: 24px; position: sticky; top: 90px; }
        .summary-card h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem; color: var(--black); margin-bottom: 20px; }
        .summary-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; font-size: 0.88rem; color: var(--gray-500); }
        .summary-row.free { color: #16a34a; font-weight: 600; }
        .summary-total { display: flex; justify-content: space-between; align-items: center; padding-top: 16px; margin-top: 8px; border-top: 2px solid var(--gray-200); }
        .summary-total span:first-child { font-weight: 700; font-size: 0.95rem; color: var(--black); }
        .summary-total span:last-child { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.3rem; color: var(--purple-mid); }
        .btn-checkout { display: block; background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 13px; font-size: 0.92rem; font-weight: 700; font-family: 'DM Sans', sans-serif; text-align: center; text-decoration: none; width: 100%; margin-top: 18px; transition: background 0.2s, transform 0.15s; cursor: pointer; }
        .btn-checkout:hover { background: var(--purple-mid); color: var(--white); transform: translateY(-1px); }
        .btn-continue { display: block; text-align: center; margin-top: 12px; color: var(--gray-500); font-size: 0.82rem; text-decoration: none; }
        .btn-continue:hover { color: var(--purple-mid); }

        /* ── EMPTY ── */
        .empty-cart { text-align: center; padding: 80px 20px; background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); }
        .empty-cart i { font-size: 3.5rem; color: var(--gray-200); display: block; margin-bottom: 16px; }
        .empty-cart h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.2rem; color: var(--black); margin-bottom: 8px; }
        .empty-cart p { color: var(--gray-500); font-size: 0.88rem; margin-bottom: 24px; }
        .btn-shop { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 12px 28px; font-size: 0.9rem; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: background 0.2s; }
        .btn-shop:hover { background: var(--purple-mid); color: var(--white); }

        /* ── FOOTER ── */
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <form class="search-wrap" action="/search" method="GET">
            <input type="search" name="q" placeholder="Search products, brands, categories...">
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
        <ul class="nav-right">
            <li><a class="nav-link" href="/vulnerabilities"><i class="bi bi-question-circle"></i> Help</a></li>
            <% if (user && user.role === 'user' && !user.isSeller) { %>
                <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
            <% } %>
            <% if (user && user.isSeller) { %>
                <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
                <li><a href="/seller/dashboard" class="btn-dashboard"><i class="bi bi-graph-up"></i> Dashboard</a></li>
            <% } %>
            <li>
                <% if (user) { %>
                    <a href="/profile" class="user-chip"><%= user.username %></a>
                    <a href="/logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-login"><i class="bi bi-person"></i> Login / Signup</a>
                <% } %>
            </li>
            <li>
                <a class="btn-cart" href="/cart">
                    <i class="bi bi-cart3"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                </a>
            </li>
        </ul>
    </div>
</nav>

<div class="page-wrap">
    <h1 class="page-title"><i class="bi bi-bag" style="color:var(--purple-mid)"></i> Shopping Cart</h1>

    <% if (items.length === 0) { %>
        <div class="empty-cart">
            <i class="bi bi-bag-x"></i>
            <h3>Your cart is empty</h3>
            <p>Browse our categories and add items to get started.</p>
            <a href="/" class="btn-shop"><i class="bi bi-grid"></i> Continue Shopping</a>
        </div>
    <% } else { %>
        <div class="cart-layout">


            <div class="cart-card">
                <div class="cart-card-header"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %> in your cart</div>
                <% items.forEach(item => { %>
                    <div class="cart-item">
                        <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.name %>">
                        <div>
                            <div class="item-name">
                                <% if (item.deal_label) { %><span style="font-size:0.62rem;font-weight:800;background:linear-gradient(90deg,#f59e0b,#ef4444);color:#fff;padding:1px 7px;border-radius:3px;margin-right:5px;text-transform:uppercase;letter-spacing:0.4px;"><%= item.deal_label %></span><% } %>
                                <%= item.name %>
                            </div>
                            <% if (item.deal_price != null) { %>
                            <div class="item-unit-price">₦<%= fmtPrice(item.effective_price) %> each <span style="text-decoration:line-through;color:#9ca3af;font-size:0.8rem;">₦<%= fmtPrice(item.price) %></span></div>
                            <% } else { %>
                            <div class="item-unit-price">₦<%= fmtPrice(item.price) %> each</div>
                            <% } %>
                        </div>

                        <form action="/cart/update" method="POST" id="qty-form-<%= item.id %>">
                            <input type="hidden" name="item_id" value="<%= item.id %>">
                            <div class="qty-stepper">
                                <button type="button" onclick="stepQty(<%= item.id %>, -1)">−</button>
                                <input type="number" name="quantity" id="qty-<%= item.id %>"
                                       value="<%= item.quantity %>" min="1" max="99"
                                       onchange="document.getElementById('qty-form-<%= item.id %>').submit()">
                                <button type="button" onclick="stepQty(<%= item.id %>,  1)">+</button>
                            </div>
                        </form>
                        <div class="item-subtotal" id="subtotal-<%= item.id %>">₦<%= parseFloat(item.subtotal).toFixed(2) %></div>
                        <form action="/cart/remove/<%= item.id %>" method="POST">
                            <button type="submit" class="btn-remove"><i class="bi bi-trash3"></i></button>
                        </form>
                    </div>
                <% }); %>
            </div>


            <div class="summary-card">
                <h3>Order Summary</h3>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>₦<%= total %></span>
                </div>
                <div class="summary-row free">
                    <span>Shipping</span>
                    <span><i class="bi bi-check-circle-fill"></i> FREE</span>
                </div>
                <div class="summary-total">
                    <span>Total</span>
                    <span>₦<%= total %></span>
                </div>
                <a href="/checkout" class="btn-checkout">
                    <i class="bi bi-lock-fill"></i> Proceed to Checkout
                </a>
                <a href="/" class="btn-continue"><i class="bi bi-arrow-left"></i> Continue Shopping</a>
            </div>

        </div>
    <% } %>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script>

const unitPrices = {
    <% items.forEach((item, idx) => { %><%= item.id %>: <%= parseFloat(item.effective_price || item.price) %><%= idx < items.length - 1 ? ',' : '' %>
    <% }); %>
};

function stepQty(itemId, delta) {
    const input = document.getElementById('qty-' + itemId);
    const next  = Math.max(1, Math.min(99, parseInt(input.value || 1) + delta));
    input.value = next;

    const sub = document.getElementById('subtotal-' + itemId);
    if (sub && unitPrices[itemId]) {
        sub.textContent = '₦' + (unitPrices[itemId] * next).toFixed(2);
    }
    document.getElementById('qty-form-' + itemId).submit();
}
</script>
<script src="/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>

</body>
</html>
