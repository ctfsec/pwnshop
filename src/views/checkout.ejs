<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Pwnshop</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .nav-link-plain { color: rgba(255,255,255,0.75) !important; font-size: 0.88rem; padding: 6px 12px; border-radius: 6px; text-decoration: none; }
        .nav-link-plain:hover { background: rgba(255,255,255,0.1); color: var(--white) !important; }

        /* ── STEPS ── */
        .checkout-steps { display: flex; align-items: center; gap: 0; max-width: 400px; margin: 0 auto 32px; padding: 0; }
        .step { display: flex; flex-direction: column; align-items: center; flex: 1; }
        .step-circle { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; margin-bottom: 4px; }
        .step.done .step-circle { background: var(--purple-mid); color: var(--white); }
        .step.active .step-circle { background: var(--purple-deep); color: var(--white); }
        .step.pending .step-circle { background: var(--gray-200); color: var(--gray-500); }
        .step-label { font-size: 0.72rem; color: var(--gray-500); font-weight: 500; }
        .step.active .step-label { color: var(--purple-deep); font-weight: 700; }
        .step-line { flex: 1; height: 2px; background: var(--gray-200); margin: 0 4px; margin-top: -18px; align-self: flex-start; }
        .step-line.done { background: var(--purple-mid); }

        /* ── PAGE ── */
        .page-wrap { max-width: 1100px; margin: 36px auto; padding: 0 20px 60px; }
        .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; color: var(--black); margin-bottom: 8px; }
        .page-subtitle { color: var(--gray-500); font-size: 0.88rem; margin-bottom: 32px; }

        /* ── LAYOUT ── */
        .checkout-layout { display: grid; grid-template-columns: 1fr 380px; gap: 24px; align-items: start; }

        /* ── FORM CARD ── */
        .form-card { background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); padding: 28px; }
        .form-card h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem; color: var(--black); margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
        .f-label { font-size: 0.78rem; font-weight: 600; color: var(--black); margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; display: block; }
        .f-field { border: 1.5px solid var(--gray-200); border-radius: 10px; padding: 11px 14px; font-size: 0.9rem; font-family: 'DM Sans', sans-serif; width: 100%; outline: none; transition: border-color 0.2s, box-shadow 0.2s; color: var(--black); background: var(--white); }
        .f-field:focus { border-color: var(--purple-mid); box-shadow: 0 0 0 3px rgba(109,40,217,0.08); }
        .f-field::placeholder { color: #b0afc0; }
        textarea.f-field { resize: vertical; min-height: 100px; }
        .divider-line { height: 1px; background: var(--gray-200); margin: 24px 0; }

        /* ── COUPON ── */
        .coupon-wrap { border: 1.5px solid var(--gray-200); border-radius: 12px; padding: 16px 18px; margin-bottom: 20px; background: var(--gray-100); }
        .coupon-wrap h4 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.82rem; color: var(--black); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
        .coupon-row { display: flex; gap: 8px; }
        .coupon-input { flex: 1; border: 1.5px solid var(--gray-200); border-radius: 9px; padding: 10px 14px; font-size: 0.88rem; font-family: 'DM Sans', sans-serif; outline: none; background: var(--white); color: var(--black); text-transform: uppercase; letter-spacing: 1px; transition: border-color 0.2s; }
        .coupon-input:focus { border-color: var(--purple-mid); }
        .coupon-input::placeholder { text-transform: none; letter-spacing: 0; color: #b0afc0; }
        .btn-apply { background: var(--purple-deep); color: var(--white); border: none; border-radius: 9px; padding: 10px 20px; font-size: 0.85rem; font-weight: 700; font-family: 'DM Sans', sans-serif; cursor: pointer; white-space: nowrap; transition: background 0.2s; }
        .btn-apply:hover { background: var(--purple-mid); }
        .coupon-msg { margin-top: 8px; font-size: 0.8rem; font-weight: 600; display: none; }
        .coupon-msg.ok  { color: #16a34a; }
        .coupon-msg.err { color: #dc2626; }
        .discount-line { display: flex; justify-content: space-between; font-size: 0.88rem; color: #16a34a; font-weight: 600; margin-bottom: 8px; display: none; }

        /* ── WALLET PANEL ── */
        .wallet-panel { background: linear-gradient(135deg, var(--purple-deep), var(--purple-mid)); border-radius: 12px; padding: 20px; color: var(--white); margin-bottom: 20px; }
        .wallet-panel .w-label { font-size: 0.78rem; opacity: 0.7; margin-bottom: 4px; }
        .wallet-panel .w-amount { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.6rem; }
        .wallet-panel .w-desc { font-size: 0.8rem; opacity: 0.75; margin-top: 8px; display: flex; align-items: center; gap: 5px; }
        .payment-choice-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
        .payment-choice { border: 1.5px solid var(--gray-200); border-radius: 10px; padding: 10px 12px; display: flex; align-items: center; gap: 8px; background: var(--white); }
        .payment-choice input { accent-color: var(--purple-mid); }
        .payment-choice strong { font-size: 0.82rem; }
        .payment-choice span { font-size: 0.74rem; color: var(--gray-500); }
        .card-panel { border: 1.5px solid var(--gray-200); border-radius: 12px; padding: 16px; margin-bottom: 16px; background: var(--gray-100); display: none; }
        .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .alert-payment { background: #fef2f2; border: 1.5px solid #fecaca; color: #dc2626; border-radius: 10px; padding: 12px 14px; font-size: 0.82rem; display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
        .alert-insufficient { background: #fef2f2; border: 1.5px solid #fecaca; color: #dc2626; border-radius: 10px; padding: 14px 16px; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
        .btn-place-order { background: var(--purple-deep); color: var(--white); border: none; border-radius: 10px; padding: 13px; font-size: 0.92rem; font-weight: 700; font-family: 'DM Sans', sans-serif; width: 100%; cursor: pointer; transition: background 0.2s, transform 0.15s; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-place-order:hover { background: var(--purple-mid); transform: translateY(-1px); }
        .btn-place-order:disabled { background: var(--gray-200); color: var(--gray-500); cursor: not-allowed; transform: none; }
        .btn-back-cart { display: block; text-align: center; margin-top: 12px; color: var(--gray-500); font-size: 0.82rem; text-decoration: none; }
        .btn-back-cart:hover { color: var(--purple-mid); }

        /* ── ORDER SUMMARY CARD ── */
        .summary-card { background: var(--white); border-radius: 16px; border: 1.5px solid var(--gray-200); padding: 24px; position: sticky; top: 90px; }
        .summary-card h3 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem; color: var(--black); margin-bottom: 16px; }
        .order-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 12px 0; border-bottom: 1px solid var(--gray-200); gap: 10px; }
        .order-item:last-child { border-bottom: none; }
        .order-item-name { font-weight: 600; font-size: 0.88rem; color: var(--black); }
        .order-item-qty { font-size: 0.78rem; color: var(--gray-500); margin-top: 2px; }
        .order-item-price { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem; color: var(--purple-mid); white-space: nowrap; }
        .summary-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.88rem; color: var(--gray-500); margin-bottom: 8px; }
        .summary-row.free { color: #16a34a; font-weight: 600; }
        .summary-total { display: flex; justify-content: space-between; align-items: center; padding-top: 14px; margin-top: 8px; border-top: 2px solid var(--gray-200); }
        .summary-total span:first-child { font-weight: 700; font-size: 0.95rem; }
        .summary-total span:last-child { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.3rem; color: var(--purple-mid); }

        /* ── FOOTER ── */
    </style>
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>

<nav class="topbar">
    <div class="container">
        <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
        <form class="search-wrap" action="/search" method="GET">
            <input type="search" name="q" placeholder="Search products, brands, categories...">
            <button type="submit"><i class="bi bi-search"></i></button>
        </form>
        <ul class="nav-right">
            <li><a class="nav-link" href="/vulnerabilities"><i class="bi bi-question-circle"></i> Help</a></li>
            <% if (user && user.role === 'user' && !user.isSeller) { %>
                <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
            <% } %>
            <% if (user && user.isSeller) { %>
                <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
                <li><a href="/seller/dashboard" class="btn-dashboard"><i class="bi bi-graph-up"></i> Dashboard</a></li>
            <% } %>
            <li>
                <% if (user) { %>
                    <a href="/profile" class="user-chip"><%= user.username %></a>
                    <a href="/logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
                <% } else { %>
                    <a href="/login" class="btn-login"><i class="bi bi-person"></i> Login / Signup</a>
                <% } %>
            </li>
            <li>
                <a class="btn-cart" href="/cart">
                    <i class="bi bi-cart3"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                </a>
            </li>
        </ul>
    </div>
</nav>

<div class="page-wrap">
    <h1 class="page-title">Checkout</h1>
    <p class="page-subtitle">Review your order and enter your shipping details to complete your purchase.</p>

    <div class="checkout-layout">


        <div>
            <div class="form-card">
                <h3><i class="bi bi-geo-alt-fill" style="color:var(--purple-mid)"></i> Delivery</h3>
                <form action="/checkout" method="POST">
                    <!-- hidden fields updated by JS -->
                    <input type="hidden" name="shipping_address" id="shipping_address">
                    <input type="hidden" name="delivery_zone"    id="delivery_zone_hidden" value="<%= savedZone %>">

                    <!-- Delivery type toggle -->
                    <div class="delivery-type-wrap" style="display:flex;gap:10px;margin-bottom:20px;">
                        <label class="delivery-type-btn" id="btn-home" style="flex:1;display:flex;align-items:center;gap:10px;border:2px solid var(--purple-mid);border-radius:12px;padding:14px 16px;cursor:pointer;background:var(--purple-pale);">
                            <input type="radio" name="_delivery_type" value="home" checked style="display:none;">
                            <i class="bi bi-house-door-fill" style="color:var(--purple-mid);font-size:1.3rem;"></i>
                            <div><strong style="font-size:0.9rem;">Home Delivery</strong><br><span style="font-size:0.75rem;color:var(--gray-500);">Deliver to my address</span></div>
                        </label>
                        <label class="delivery-type-btn" id="btn-pickup" style="flex:1;display:flex;align-items:center;gap:10px;border:2px solid var(--gray-200);border-radius:12px;padding:14px 16px;cursor:pointer;background:var(--white);">
                            <input type="radio" name="_delivery_type" value="pickup" style="display:none;">
                            <i class="bi bi-shop" style="color:var(--gray-500);font-size:1.3rem;" id="pickup-icon"></i>
                            <div><strong style="font-size:0.9rem;">Pickup Store</strong><br><span style="font-size:0.75rem;color:var(--gray-500);">Collect from our store</span></div>
                        </label>
                    </div>

                    <!-- Home Delivery panel -->
                    <div id="panel-home">
                        <% if (!savedAddress) { %>
                        <div style="background:#fffbeb;border:1px solid #fcd34d;border-radius:10px;padding:12px 14px;margin-bottom:14px;font-size:0.84rem;color:#92400e;display:flex;align-items:center;gap:8px;">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            You have no default address set.
                            <a href="/profile" style="color:var(--purple-mid);font-weight:700;margin-left:4px;">Set it on your profile</a>
                        </div>
                        <% } %>
                        <label class="f-label">Delivery Address</label>
                        <textarea class="f-field" id="homeAddress" rows="3"
                            placeholder="Enter your full address including street, city, state and postal code"
                            oninput="syncHomeAddress(this.value)"><%= savedAddress %></textarea>
                        <div style="margin-top:10px;">
                            <label class="f-label">Delivery Zone</label>
                            <select class="f-field" id="homeZone" onchange="updateZone(this.value)">
                                <option value="lagos"  <%= savedZone === 'lagos'  ? 'selected' : '' %>>Lagos (₦800)</option>
                                <option value="others" <%= savedZone === 'others' ? 'selected' : '' %>>Other States (₦1,500)</option>
                                <option value="remote" <%= savedZone === 'remote' ? 'selected' : '' %>>Remote Area (₦2,500)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Pickup Store panel -->
                    <div id="panel-pickup" style="display:none;">
                        <label class="f-label">Select Pickup Store</label>
                        <select class="f-field" id="storeSelect" onchange="selectStore(this.value)">
                            <option value="">-- Choose a store --</option>
                            <% pickupStores.forEach(function(s) { %>
                                <option value="<%= s.id %>" data-address="<%= s.address %>" data-zone="<%= s.zone %>">
                                    <%= s.name %> - <%= s.address %>
                                </option>
                            <% }); %>
                        </select>
                        <div id="storeInfo" style="display:none;margin-top:10px;background:var(--gray-100);border-radius:9px;padding:10px 13px;font-size:0.82rem;color:var(--gray-500);">
                            <i class="bi bi-geo-alt-fill" style="color:var(--purple-mid);"></i>
                            <span id="storeInfoText"></span>
                        </div>
                    </div>

                    <div class="divider-line" style="margin-top:18px;"></div>


                    <div class="coupon-wrap">
                        <h4><i class="bi bi-tag" style="color:var(--purple-mid)"></i> Promo Code</h4>
                        <div class="coupon-row">
                            <input type="text" class="coupon-input" id="couponInput" placeholder="Enter code (e.g. HALFOFF)">
                            <button type="button" class="btn-apply" id="applyBtn">Apply</button>
                        </div>
                        <div class="coupon-msg" id="couponMsg"></div>
                        <input type="hidden" name="coupon_code" id="couponCode">
                    </div>

                    <div class="divider-line"></div>

                    <h3 style="font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
                        <i class="bi bi-wallet2" style="color:var(--purple-mid)"></i> Payment
                    </h3>

                    <% if (checkoutError) { %>
                    <div class="alert-payment">
                        <i class="bi bi-x-octagon-fill"></i>
                        <%= checkoutError %>
                    </div>
                    <% } %>

                    <div class="payment-choice-wrap">
                        <label class="payment-choice">
                            <input type="radio" name="payment_method" value="wallet" <%= selectedPaymentMethod !== 'vulnbank_card' ? 'checked' : '' %>>
                            <div>
                                <strong>Wallet</strong><br>
                                <span>Use local Pwnshop wallet</span>
                            </div>
                        </label>
                        <label class="payment-choice" style="<%= vulnbankEnabled ? '' : 'opacity:0.5;' %>">
                            <input type="radio" name="payment_method" value="vulnbank_card" <%= selectedPaymentMethod === 'vulnbank_card' ? 'checked' : '' %> <%= vulnbankEnabled ? '' : 'disabled' %>>
                            <div>
                                <strong>Vulnbank Card</strong><br>
                                <span><%= vulnbankEnabled ? 'Pay directly with virtual card' : 'Not configured by admin' %></span>
                            </div>
                        </label>
                    </div>

                    <div class="wallet-panel">
                        <div class="w-label">Wallet Balance</div>
                        <div class="w-amount">₦<%= parseFloat(user.wallet_amount || 0).toFixed(2) %></div>
                        <div class="w-desc"><i class="bi bi-info-circle"></i> Wallet remains available even when using Vulnbank card.</div>
                    </div>

                    <div class="card-panel" id="vulnbankCardPanel">
                        <div class="mb-2">
                            <label class="f-label">Card Number</label>
                            <input class="f-field" type="text" name="vb_card_number" id="vbCardNumber" placeholder="4111 1111 1111 1111">
                        </div>
                        <div class="card-grid">
                            <div>
                                <label class="f-label">Expiry</label>
                                <input class="f-field" type="text" name="vb_card_expiry" id="vbCardExpiry" placeholder="MM/YY">
                            </div>
                            <div>
                                <label class="f-label">CVV</label>
                                <input class="f-field" type="password" name="vb_card_cvv" id="vbCardCvv" placeholder="123">
                            </div>
                        </div>
                        <div class="mt-2">
                            <label class="f-label">Card Holder Name</label>
                            <input class="f-field" type="text" name="vb_card_name" id="vbCardName" value="<%= user.username %>">
                        </div>
                    </div>


                    <div class="alert-insufficient" id="insufficientAlert" style="display:<%= (selectedPaymentMethod !== 'vulnbank_card' && parseFloat(user.wallet_amount || 0) < parseFloat(grandTotal)) ? 'flex' : 'none' %>;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Insufficient wallet balance. Please add funds before proceeding.
                    </div>


                    <button type="submit" class="btn-place-order" id="placeOrderBtn"
                        <%= (selectedPaymentMethod !== 'vulnbank_card' && parseFloat(user.wallet_amount || 0) < parseFloat(grandTotal)) ? 'disabled' : '' %>>
                        <i class="bi bi-lock-fill"></i>
                        <span id="placeOrderLabel">
                            <%= selectedPaymentMethod === 'vulnbank_card'
                                ? 'Pay with Vulnbank - ₦' + grandTotal
                                : (parseFloat(user.wallet_amount || 0) < parseFloat(grandTotal) ? 'Insufficient Balance' : 'Place Order - ₦' + grandTotal) %>
                        </span>
                    </button>
                </form>
                <a href="/cart" class="btn-back-cart"><i class="bi bi-arrow-left"></i> Back to Cart</a>
            </div>
        </div>


        <div class="summary-card">
            <h3>Order Summary</h3>
            <div style="margin-bottom:16px;">
                <% items.forEach(item => { %>
                    <div class="order-item">
                        <div>
                            <div class="order-item-name"><%= item.name %></div>
                            <div class="order-item-qty">Qty <%= item.quantity %> × ₦<%= parseFloat(item.price).toFixed(2) %></div>
                        </div>
                        <div class="order-item-price">₦<%= parseFloat(item.subtotal).toFixed(2) %></div>
                    </div>
                <% }); %>
            </div>
            <div class="summary-row"><span>Subtotal</span><span>₦<%= total %></span></div>
            <div class="summary-row" id="discountRow" style="display:none;color:#16a34a;font-weight:600;"><span id="discountLabel">Discount</span><span id="discountAmt"></span></div>
            <div class="summary-row"><span>Logistics Fee</span><span id="logisticsDisplay">₦<%= logisticsFee %></span></div>
            <div class="summary-total"><span>Grand Total</span><span id="totalDisplay">₦<%= grandTotal %></span></div>
        </div>
    </div>
</div>

<footer>
    &copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.
</footer>

<script>
const baseTotal      = parseFloat('<%= total %>');
const walletBalance  = parseFloat('<%= parseFloat(user.wallet_amount || 0).toFixed(2) %>');
const applyBtn       = document.getElementById('applyBtn');
const couponInput    = document.getElementById('couponInput');
const couponCode     = document.getElementById('couponCode');
const couponMsg      = document.getElementById('couponMsg');
const totalDisplay   = document.getElementById('totalDisplay');
const logisticsDisplay = document.getElementById('logisticsDisplay');
const discountRow    = document.getElementById('discountRow');
const discountAmt    = document.getElementById('discountAmt');
const discountLbl    = document.getElementById('discountLabel');
const placeBtn       = document.getElementById('placeOrderBtn');
const placeLabel     = document.getElementById('placeOrderLabel');
const alertBox       = document.getElementById('insufficientAlert');
const paymentInputs  = document.querySelectorAll('input[name="payment_method"]');
const cardPanel      = document.getElementById('vulnbankCardPanel');
const cardNumber     = document.getElementById('vbCardNumber');
const cardExpiry     = document.getElementById('vbCardExpiry');
const cardCvv        = document.getElementById('vbCardCvv');
const ZONE_FEES      = { lagos: 800, others: 1500, remote: 2500 };
const STORES         = <%- JSON.stringify(pickupStores) %>;
let currentZoneFee   = parseFloat('<%= logisticsFee %>');
let discountAmount   = 0;
let effectiveTotal   = baseTotal + currentZoneFee;

/* ── VulnBank card input formatting ── */
cardNumber.addEventListener('input', function() {
    let v = this.value.replace(/\D/g, '').slice(0, 16);
    this.value = v.match(/.{1,4}/g)?.join(' ') || v;
});
cardNumber.addEventListener('keydown', function(e) {
    if (!/[\d\b]/.test(e.key) && !['ArrowLeft','ArrowRight','Delete','Tab','Backspace'].includes(e.key)) e.preventDefault();
});
cardExpiry.addEventListener('input', function() {
    let v = this.value.replace(/\D/g, '').slice(0, 4);
    this.value = v.length > 2 ? v.slice(0,2) + '/' + v.slice(2) : v;
});
cardExpiry.addEventListener('keydown', function(e) {
    if (!/[\d\b]/.test(e.key) && !['ArrowLeft','ArrowRight','Delete','Tab','Backspace'].includes(e.key)) e.preventDefault();
});
cardCvv.addEventListener('input', function() {
    this.value = this.value.replace(/\D/g, '').slice(0, 4);
});
cardCvv.addEventListener('keydown', function(e) {
    if (!/[\d\b]/.test(e.key) && !['ArrowLeft','ArrowRight','Delete','Tab','Backspace'].includes(e.key)) e.preventDefault();
});

/* Sync home address textarea → hidden field */
function syncHomeAddress(val) {
    document.getElementById('shipping_address').value = val;
}

/* Called when home zone select changes */
function updateZone(zone) {
    document.getElementById('delivery_zone_hidden').value = zone;
    currentZoneFee = ZONE_FEES[zone] || 1500;
    logisticsDisplay.textContent = '₦' + currentZoneFee.toLocaleString();
    const grand = Math.max(0, baseTotal - discountAmount) + currentZoneFee;
    effectiveTotal = grand;
    totalDisplay.textContent = '₦' + grand.toLocaleString('en-NG', {minimumFractionDigits: 2});
    updateButtonState(effectiveTotal);
}

/* Called when store dropdown changes */
function selectStore(storeId) {
    const store = STORES.find(s => s.id === storeId);
    const info  = document.getElementById('storeInfo');
    const txt   = document.getElementById('storeInfoText');
    if (!store) { info.style.display = 'none'; return; }
    document.getElementById('shipping_address').value        = store.address;
    document.getElementById('delivery_zone_hidden').value    = store.zone;
    txt.textContent = store.address;
    info.style.display = 'block';
    updateZone(store.zone);
}

/* Delivery type toggle (Home / Pickup) */
(function() {
    const typeInputs = document.querySelectorAll('input[name="_delivery_type"]');
    const panelHome   = document.getElementById('panel-home');
    const panelPickup = document.getElementById('panel-pickup');
    const btnHome     = document.getElementById('btn-home');
    const btnPickup   = document.getElementById('btn-pickup');
    const pickupIcon  = document.getElementById('pickup-icon');

    function switchType(type) {
        if (type === 'home') {
            panelHome.style.display   = '';
            panelPickup.style.display = 'none';
            btnHome.style.borderColor   = 'var(--purple-mid)';
            btnHome.style.background    = 'var(--purple-pale)';
            btnPickup.style.borderColor = 'var(--gray-200)';
            btnPickup.style.background  = 'var(--white)';
            pickupIcon.style.color      = 'var(--gray-500)';
            /* Restore home address + zone */
            const addr = document.getElementById('homeAddress').value;
            const zone = document.getElementById('homeZone').value;
            syncHomeAddress(addr);
            updateZone(zone);
        } else {
            panelHome.style.display   = 'none';
            panelPickup.style.display = '';
            btnPickup.style.borderColor = 'var(--purple-mid)';
            btnPickup.style.background  = 'var(--purple-pale)';
            btnHome.style.borderColor   = 'var(--gray-200)';
            btnHome.style.background    = 'var(--white)';
            pickupIcon.style.color      = 'var(--purple-mid)';
            /* Reset hidden fields until user picks a store */
            document.getElementById('shipping_address').value     = '';
            document.getElementById('delivery_zone_hidden').value = 'others';
            document.getElementById('storeInfo').style.display    = 'none';
        }
    }

    typeInputs.forEach(inp => inp.addEventListener('change', () => switchType(inp.value)));
    /* Init hidden address from saved */
    syncHomeAddress(document.getElementById('homeAddress').value);
})();

function currentPaymentMethod() {
    const selected = document.querySelector('input[name="payment_method"]:checked');
    return selected ? selected.value : 'wallet';
}

function updateButtonState(effectiveTotal) {
    if (currentPaymentMethod() === 'vulnbank_card') {
        placeBtn.disabled = false;
        placeLabel.textContent = 'Pay with Vulnbank - ₦' + effectiveTotal.toFixed(2);
        alertBox.style.display = 'none';
        return;
    }

    if (walletBalance < effectiveTotal) {
        placeBtn.disabled = true;
        placeLabel.textContent = 'Insufficient Balance';
        alertBox.style.display = 'flex';
    } else {
        placeBtn.disabled = false;
        placeLabel.textContent = 'Place Order - ₦' + effectiveTotal.toFixed(2);
        alertBox.style.display = 'none';
    }
}

function syncPaymentMethodUi() {
    const isCard = currentPaymentMethod() === 'vulnbank_card';
    cardPanel.style.display = isCard ? 'block' : 'none';
    cardNumber.required = isCard;
    cardExpiry.required = isCard;
    cardCvv.required = isCard;
    updateButtonState(effectiveTotal);
}

paymentInputs.forEach((input) => {
    input.addEventListener('change', syncPaymentMethodUi);
});

syncPaymentMethodUi();

applyBtn.addEventListener('click', async () => {
    const code = couponInput.value.trim();
    if (!code) return;

    applyBtn.textContent = 'Checking…';
    applyBtn.disabled = true;

    try {
        const resp = await fetch('/apply-coupon', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, cart_total: baseTotal })
        });
        const data = await resp.json();

        couponMsg.style.display = 'block';
        if (data.valid) {
            couponMsg.className = 'coupon-msg ok';
            couponMsg.textContent = data.message;
            couponCode.value = code.toUpperCase();
            discountAmount = baseTotal - parseFloat(data.new_total);
            const grandWithDiscount = parseFloat(data.new_total) + currentZoneFee;
            totalDisplay.textContent = '₦' + grandWithDiscount.toLocaleString('en-NG', {minimumFractionDigits: 2});
            discountRow.style.display = 'flex';
            discountLbl.textContent = data.discount_percent + '% off';
            discountAmt.textContent = '−₦' + data.discount_amount;
            applyBtn.textContent = '✓ Applied';
            couponInput.disabled = true;
            effectiveTotal = grandWithDiscount;
            updateButtonState(effectiveTotal);
        } else {
            couponMsg.className = 'coupon-msg err';
            couponMsg.textContent = data.message;
            couponCode.value = '';
            applyBtn.textContent = 'Apply';
            applyBtn.disabled = false;
        }
    } catch(e) {
        couponMsg.style.display = 'block';
        couponMsg.className = 'coupon-msg err';
        couponMsg.textContent = 'Could not apply coupon.';
        applyBtn.textContent = 'Apply';
        applyBtn.disabled = false;
    }
});
</script>
<script src="/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>

</body>
</html>
