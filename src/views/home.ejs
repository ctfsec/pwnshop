<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pwnshop - Home</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/mobile-responsive.css">
</head>
<body>
    <nav class="topbar">
        <div class="container">
            <a class="navbar-brand" href="/">Pwnshop<span class="dot"></span></a>
            <form class="search-wrap" action="/search" method="GET">
                <input type="search" name="q" placeholder="Search products, brands, categories...">
                <button type="submit"><i class="bi bi-search"></i></button>
            </form>
            <ul class="nav-right">
                <li><a class="nav-link" href="/vulnerabilities"><i class="bi bi-question-circle"></i> Help</a></li>
                <% if (user && user.role === 'user' && !user.isSeller) { %>
                    <li><a href="/register-seller" class="btn-seller">Become a Seller</a></li>
                <% } %>
                <% if (user && user.isSeller) { %>
                    <li><a href="/add-product" class="btn-add-product">+ Add Product</a></li>
                    <li><a href="/seller/dashboard" class="btn-dashboard"><i class="bi bi-graph-up"></i> Dashboard</a></li>
                <% } %>
                <li>
                    <% if (user) { %>
                        <a href="/profile" class="user-chip"><%= user.username %></a>
                        <a href="/logout" class="btn-logout ms-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
                    <% } else { %>
                        <a href="/login" class="btn-login"><i class="bi bi-person"></i> Login / Signup</a>
                    <% } %>
                </li>
                <li>
                    <a class="btn-cart" href="/cart">
                        <i class="bi bi-cart3"></i> My Cart <span class="badge ms-1"><%= cartCount %></span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="page-wrap two-col">
        <aside class="sidebar-col">
            <div class="sidebar">
                <h5>Categories</h5>
                <a href="/category/all"         class="cat-btn active"><span class="cat-icon"><i class="bi bi-grid-fill"></i></span> All Categories</a>
                <a href="/category/computers"   class="cat-btn"><span class="cat-icon"><i class="bi bi-laptop"></i></span> Computers &amp; Accessories</a>
                <a href="/category/phones"      class="cat-btn"><span class="cat-icon"><i class="bi bi-phone"></i></span> Phones &amp; Tablets</a>
                <a href="/category/electronics" class="cat-btn"><span class="cat-icon"><i class="bi bi-lightning-charge"></i></span> Electronics</a>
                <a href="/category/fashion"     class="cat-btn"><span class="cat-icon"><i class="bi bi-bag"></i></span> Fashion</a>
                <a href="/category/home"        class="cat-btn"><span class="cat-icon"><i class="bi bi-house"></i></span> Home &amp; Kitchen</a>
                <a href="/category/kids"        class="cat-btn"><span class="cat-icon"><i class="bi bi-star"></i></span> Kids &amp; Toys</a>
                <a href="/category/beauty"      class="cat-btn"><span class="cat-icon"><i class="bi bi-heart"></i></span> Beauty &amp; Health</a>
            </div>
            <%
                const _fsExpiry = new Date('2036-01-01');
                const _fsDays   = Math.max(0, Math.ceil((_fsExpiry - new Date()) / (1000*60*60*24)));
            %>
            <div class="sidebar-promo" style="min-height:203px;display:flex;flex-direction:column;justify-content:center;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                    <h6 style="margin:0;">Flash Sale 🔥</h6>
                    <span style="font-size:0.68rem;font-weight:700;background:rgba(255,255,255,0.2);padding:2px 8px;border-radius:20px;white-space:nowrap;"><%= _fsDays %>d left</span>
                </div>
                <p>Up to 60% off selected items</p>
                <a href="/category/all" class="promo-btn">Shop Now</a>
            </div>
        </aside>

        <main>
            <div id="promoCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="https://images.unsplash.com/photo-1498049794561-7780e7231661?w=1200&h=400&fit=crop" alt="Electronics Sale">
                        <div class="carousel-caption">
                            <h2>Big Summer Sale!</h2>
                            <p>Up to 50% off on Electronics</p>
                            <a href="/category/electronics" class="btn btn-light btn-lg">Shop Now →</a>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="https://images.unsplash.com/photo-1445205170230-053b83016050?w=1200&h=400&fit=crop" alt="Fashion">
                        <div class="carousel-caption">
                            <h2>Fashion Fiesta</h2>
                            <p>Trendy styles for everyone</p>
                            <a href="/category/fashion" class="btn btn-light btn-lg">See Deals →</a>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&h=400&fit=crop" alt="Home & Kitchen">
                        <div class="carousel-caption">
                            <h2>Home &amp; Kitchen Essentials</h2>
                            <p>Upgrade your space with great offers</p>
                            <a href="/category/home" class="btn btn-light btn-lg">Shop Home →</a>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#promoCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
                <button class="carousel-control-next" type="button" data-bs-target="#promoCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
            </div>

            <h2 class="section-heading">Featured Sellers</h2>
            <div class="row g-3 mb-5">
                <% if (users && users.length > 0) { %>
                    <% users.forEach(function(seller) {
                        const sellerProducts = products.filter(p => p.seller_id === seller.id);
                        const sellerProduct = sellerProducts.length > 0 ? sellerProducts[Math.floor(Math.random() * sellerProducts.length)] : null;
                        const cardHref = sellerProduct ? '/product/' + sellerProduct.id : null;
                    %>
                        <div class="col-md-3 col-sm-6">
                            <% if (cardHref) { %>
                            <a href="<%= cardHref %>" style="text-decoration:none;display:block;">
                            <% } %>
                            <div class="seller-card" style="<%= cardHref ? 'cursor:pointer;transition:transform 0.18s,box-shadow 0.18s;' : '' %>">
                                <% if (sellerProduct && sellerProduct.image) { %>
                                    <div class="product-card-img-wrap" style="border-radius:12px 12px 0 0;overflow:hidden;">
                                        <img src="<%= sellerProduct.image %>" alt="<%= sellerProduct.name %>" class="seller-card-img">
                                        <% if (sellerProduct.deal_price != null) { %>
                                        <span class="deal-pct-badge">-<%= Math.round((1 - parseFloat(sellerProduct.deal_price)/parseFloat(sellerProduct.price))*100) %>%</span>
                                        <% } %>
                                    </div>
                                <% } else { %>
                                    <div class="seller-card-img-placeholder">🛍️</div>
                                <% } %>
                                <div class="seller-card-body">
                                    <% if (sellerProduct) { %>
                                        <div class="seller-product-name"><%= sellerProduct.name %></div>
                                        <% if (sellerProduct.deal_price != null) { %>
                                        <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:0.88rem;color:var(--purple-mid);margin-bottom:2px;">
                                            ₦<%= fmtPrice(sellerProduct.deal_price) %>
                                            <span style="font-size:0.72rem;font-weight:400;color:var(--gray-500);text-decoration:line-through;font-family:'DM Sans',sans-serif;">₦<%= fmtPrice(sellerProduct.price) %></span>
                                        </div>
                                        <% } else { %>
                                        <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:0.88rem;color:var(--purple-mid);margin-bottom:2px;">
                                            ₦<%= fmtPrice(sellerProduct.price) %>
                                        </div>
                                        <% } %>
                                    <% } else { %>
                                        <div class="seller-product-name" style="color:var(--gray-500);">No product yet</div>
                                    <% } %>
                                    <div class="seller-name"><%= seller.username %></div>
                                    <% if (seller.seller_tagline) { %>
                                        <div class="seller-tagline"><%= seller.seller_tagline %></div>
                                    <% } %>
                                </div>
                            </div>
                            <% if (cardHref) { %>
                            </a>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>

            <h2 class="section-heading">Popular Products</h2>
            <div class="row g-4">
                <% products.forEach(function(product) { %>
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="product-card">
                            <div class="product-card-img-wrap">
                                <img src="<%= product.image && product.image !== '' ? product.image : '/images/pc.jpg' %>" alt="<%= product.name %>">
                                <% if (product.deal_price != null) { %>
                                <span class="deal-pct-badge">-<%= Math.round((1 - parseFloat(product.deal_price)/parseFloat(product.price))*100) %>%</span>
                                <% } %>
                            </div>
                            <div class="product-card-body">
                                <div class="product-name"><%= product.name %></div>
                                <% if (product.deal_price != null) { %>
                                <div class="product-price deal-price">₦<%= fmtPrice(product.deal_price) %> <span class="original-price">₦<%= fmtPrice(product.price) %></span></div>
                                <% } else { %>
                                <div class="product-price">₦<%= fmtPrice(product.price) %></div>
                                <% } %>
                                <span class="product-category"><%= product.category %></span>
                                <div class="product-actions">
                                    <a href="/product/<%= product.id %>" class="btn-view">View</a>
                                    <form method="POST" action="/cart/add" style="flex:1;display:flex;">
                                        <input type="hidden" name="product_id" value="<%= product.id %>">
                                        <input type="hidden" name="quantity" value="1">
                                        <button type="submit" class="btn-addcart" style="width:100%">Add to Cart</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </main>
    </div>

    <footer>&copy; <%= new Date().getFullYear() %> <strong>Pwnshop</strong>. All rights reserved.</footer>
    <script src="/js/bootstrap.bundle.min.js"></script>
    <%- include('chat-widget') %>
<script src="/js/mobile-nav.js"></script>

</body>
</html>
