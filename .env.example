# Database Configuration (only needed without Docker)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=root
DB_NAME=pwnshop

# AI Chatbot - get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Server Configuration
PORT=3000
SESSION_SECRET=weak-secret-123

# Vulnbank Merchant Integration
VULNBANK_BASE_URL=https://api.vulnbank.example
VULNBANK_AUTH_MODE=api_key_header
VULNBANK_MERCHANT_API_KEY=your_vulnbank_merchant_api_key
VULNBANK_MERCHANT_JWT=
VULNBANK_CHARGE_PATH=/merchant/charges
VULNBANK_VERIFY_PATH=/merchant/charges/{reference}
VULNBANK_TIMEOUT_MS=12000

# Lab-only toggle: when enabled, Vulnbank verification is intentionally weak
# 0 = strict verification (recommended), 1 = intentionally vulnerable lab mode
VULNBANK_LAB_VULN=0
